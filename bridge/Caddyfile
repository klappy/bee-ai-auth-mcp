# bee-ai-auth-mcp — private-CA bridge (caddy)
#
# Purpose (ledger E0012 / PRD v0.4; bound container, D0028): Bee's direct API uses
# a PRIVATE CA, which a stock Cloudflare Worker `fetch` cannot trust. This bridge
# runs as a Cloudflare Container BOUND to the relay Worker: the Worker reaches it
# over an INTERNAL Worker->container call (getContainer(env.BEE_BRIDGE).fetch(...)
# in src/bee.ts), so there is NO public hostname and NO public ACME cert on this
# leg. caddy only re-originates TLS to Bee trusting bee-ca.pem. Only /v1/* is
# forwarded; everything else is 404.
#
# HONEST + SAFEST (binding): the Authorization header is NEVER logged. Access logs
# below are structured JSON with request headers omitted by default; we do not add
# any directive that would emit `Authorization`. Do not enable `log_request_headers`
# or debug access logging.
#
# OPERATOR-FILL (facts this build cannot fabricate — see bridge/README.md):
#   {$BEE_UPSTREAM}  — Bee's REAL direct API host:port (e.g. api.bee.computer:443).
#                      The docs publish only the placeholder $BEE_API_BASE; get
#                      the real host from your bee-cli config / Bee.
#   {$BEE_SNI}       — Bee's REAL hostname for SNI + cert validation (usually the
#                      upstream host).
#   bee-ca.pem       — Bee's private CA roots, copied verbatim from
#                      github.com/bee-computer/bee-cli  sources/certs.ts.

{
	admin off
	# UNPRIVILEGED listener. caddy runs non-root (uid 65532) with every Linux
	# capability dropped (--cap-drop=ALL), so it cannot bind ports <1024. The
	# Worker->container call lands on :8080 (BeeBridge.defaultPort, src/bridge.ts).
	# There is no public 443/ACME leg — this is an internal-only bridge.
	http_port 8080
	# Structured access log WITHOUT request headers (no Authorization ever emitted).
	log {
		output stdout
		format json
	}
}

# Internal listener facing the relay Worker (the bound-container leg, D0028). A
# PORT site matches ANY Host, so the internal getContainer().fetch() — whose URL
# host is arbitrary (http://bee-bridge/...) — is served here instead of being
# 404'd by a hostname-specific site block.
:8080 {
	# Only forward the Bee developer API surface; everything else is 404.
	@notapi not path /v1/*
	respond @notapi 404

	reverse_proxy https://{$BEE_UPSTREAM} {
		# Trust Bee's private CA on the re-originated TLS leg.
		transport http {
			tls
			tls_trust_pool file /etc/caddy/bee-ca.pem
			# Present SNI / validate against Bee's real hostname.
			tls_server_name {$BEE_SNI}
		}
		# Send the upstream the Host it expects so its cert validates.
		header_up Host {$BEE_SNI}
		# Defensive: never reflect these back to clients.
		header_down -Server
	}
}
